# Copie para .env.local (local) e configure as mesmas vars na Vercel.

# --- Banco (OBRIGATÓRIO) — Supabase/Postgres ---
# Supabase → Project Settings → Database → Connection string → URI
# Use o pooler em modo TRANSACTION (porta 6543).
DATABASE_URL=postgresql://postgres.[ref]:[SENHA]@aws-0-[regiao].pooler.supabase.com:6543/postgres

# --- IA ---
# Na Vercel a IA usa a API (a assinatura/claude -p só funciona local).
# Crie em https://platform.claude.com/
ANTHROPIC_API_KEY=
# Modelo do caminho API (padrão: claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8
# (local) força um modelo no claude -p:
# CLAUDE_CLI_MODEL=claude-sonnet-4-6

# --- Login (recomendado em produção) ---
# Se definido, o app exige esta senha. Vazio = aberto (dev).
APP_PASSWORD=

# --- Telegram (opcional) ---
TELEGRAM_BOT_TOKEN=
# Segredo do webhook (defina o mesmo no setWebhook). Só usado na Vercel.
TELEGRAM_WEBHOOK_SECRET=

# --- Cron da Vercel (recomendado) ---
# A Vercel envia "Authorization: Bearer $CRON_SECRET" no cron. Proteja o endpoint.
CRON_SECRET=

# --- Prosas (opcional) ---
# PROSAS_CLIENT_ID=
